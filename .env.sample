# .env.sample
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are shown.

# =============================================================================
# discord-etl.py
# =============================================================================

# Directory containing DiscordChatExporter .json export files (searched recursively).
DISCORD_EXPORT_DIR=discord_exports

# Path for the output JSON array of kept messages.
OUTPUT_FILE=extracted_discord.json

# Path for the discard log (one line per dropped message, with reason).
DISCARD_LOG=discarded_messages.log

# Print a progress line every N messages scanned within a file.
LOG_EVERY=10000

# =============================================================================
# Language filtering — thresholds (lang_filter.py / NepaliFilter)
# =============================================================================

# Lingua confidence above which a message is considered English and discarded.
# Lower = more aggressive English removal (more false positives on short messages).
# Range: 0.0–1.0. Default: 0.5
LINGUA_ENGLISH_THRESHOLD=0.5

# Lingua confidence above which a message is considered Spanish and discarded.
# Range: 0.0–1.0. Default: 0.5
LINGUA_SPANISH_THRESHOLD=0.5

# Minimum relative distance between top two language candidates inside Lingua.
# Higher = Lingua only fires when it is more decisive; lower = fires more often.
# Range: 0.0–1.0. Default: 0.1
LINGUA_MIN_RELATIVE_DISTANCE=0.1

# Load only English + Spanish + Nepali Lingua models (~50 MB) instead of all
# 75 languages (~1 GB). Switched on automatically when free RAM < 1.2 GB.
# Set to "true" to force low-memory mode regardless of available RAM.
# Values: true | false. Default: false
LINGUA_LOW_MEMORY=false

# =============================================================================
# English density heuristic (fast pre-filter before Lingua)
# =============================================================================

# Minimum number of Latin words a message must contain to be evaluated by Lingua.
# Messages below this count are discarded outright (catches single-word noise
# like "Hi", "Lol", "damn"). Set to 1 to disable the minimum.
# Default: 3
MIN_LATIN_WORDS=3

# If the fraction of Latin words that are common English words meets or exceeds
# this threshold, the message is discarded without calling Lingua.
# Lower = more aggressive English removal. Set to 1.0 to disable.
# Range: 0.0–1.0. Default: 0.6
ENGLISH_DENSITY_THRESHOLD=0.6

# =============================================================================
# reddit-etl.py (if used alongside discord-etl.py)
# =============================================================================

# Directory containing scraped Reddit JSON data.
SCRAPED_DIR=path/to/your/scraped_reddit_data
