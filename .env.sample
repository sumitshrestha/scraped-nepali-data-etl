# .env.sample
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are shown.
# Both ETLs share the LINGUA_* variables; set them once here.

# =============================================================================
# Lingua model settings  (shared by discord-etl.py and reddit-etl.py)
# =============================================================================

# Load only EN+ES+NE Lingua models (~50 MB) instead of all 75 (~1 GB).
# Auto-enabled when free RAM < 1.2 GB (requires psutil). Force it here
# if you're on a memory-constrained machine regardless of available RAM.
# Values: true | false.  Default: false
LINGUA_LOW_MEMORY=false

# Minimum score gap between Lingua's top two language candidates before it
# will commit to naming a language. Lower = fires more on short/ambiguous
# text; higher = more abstentions (safer on short messages).
# Range: 0.0–1.0.  Default: 0.1
LINGUA_MIN_RELATIVE_DISTANCE=0.1

# Lingua confidence above which is_english() fires and the text is discarded.
# Lower = more aggressive English removal (catches more noise, risks more
# false positives on short Nepali messages).
# Range: 0.0–1.0.  Default: 0.5
LINGUA_ENGLISH_THRESHOLD=0.5

# Lingua confidence above which is_spanish() fires and the text is discarded.
# Range: 0.0–1.0.  Default: 0.5
LINGUA_SPANISH_THRESHOLD=0.5

# Lingua confidence above which is_nepali() considers text to be EN/ES and
# discards it. Higher = more conservative (keeps more ambiguous text). Used
# only by reddit-etl.py — discord-etl.py calls is_english/is_spanish directly.
# Range: 0.0–1.0.  Default: 0.85
LINGUA_NEPALI_THRESHOLD=0.85

# =============================================================================
# discord-etl.py
# =============================================================================

# Directory containing DiscordChatExporter .json export files (recursive).
DISCORD_EXPORT_DIR=discord_exports

# Path for the output JSON array of kept messages.
OUTPUT_FILE=extracted_discord.json

# Path for the discard log (one line per dropped message with reason).
DISCARD_LOG=discarded_messages.log

# Print a progress line every N messages scanned within a file.
LOG_EVERY=10000

# --- English density pre-filter (Stage 2, runs before Lingua) ---------------

# Minimum number of Latin words a message must contain to reach Lingua.
# Messages below this count are discarded immediately. Catches single-word
# noise like "Hi", "Lol", "damn". Set to 1 to effectively disable.
# Default: 3
MIN_LATIN_WORDS=3

# If the fraction of Latin words that are common English words meets or
# exceeds this value, the message is discarded without calling Lingua.
# Lower = more aggressive. Set to 1.0 to disable density filtering.
# Range: 0.0–1.0.  Default: 0.6
ENGLISH_DENSITY_THRESHOLD=0.6

# =============================================================================
# reddit-etl.py
# =============================================================================

# Directory containing scraped Reddit JSON data.
SCRAPED_DIR=path/to/your/scraped_reddit_data

# Path for the output JSON array of kept posts and comments.
REDDIT_OUTPUT_FILE=extracted_posts.json
